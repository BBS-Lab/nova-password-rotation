APP_NAME="BBS Lab - Nova Password Rotation"
APP_ENV=local
APP_KEY=AckfSECXIvnK5r28GVIWUAxmbBSjTsmF
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── Password rotation ────────────────────────────────────────────────────────
# The rotation keys live in the base package (config/laravel-password-rotation.php)
# and read these env vars. All optional and shown at their defaults; tweak while
# serving Nova — e.g. drop DAYS to 0 to force every account expired.
PASSWORD_ROTATION_ENABLED=true
PASSWORD_ROTATION_DAYS=90
PASSWORD_ROTATION_WARN_DAYS=7
PASSWORD_ROTATION_HISTORY_COUNT=3
PASSWORD_ROTATION_FORCE_FIRST_LOGIN=true
PASSWORD_ROTATION_REQUIRE_CURRENT=true
# PASSWORD_ROTATION_COLUMN=password_changed_at
# PASSWORD_ROTATION_MORPH_KEY_TYPE=   # empty=auto (bigint) | uuid | ulid

# Nova-specific keys (config/nova-password-rotation.php):
# PASSWORD_ROTATION_ROUTE_PREFIX=password-rotation
# PASSWORD_ROTATION_AUTO_MIDDLEWARE=true
# expiry_action: "change" (in-panel form) | "reset" (email a reset link + sign out).
# The "reset" action needs Nova password reset (withPasswordResetRoutes()) or a
# "password.reset" route.
PASSWORD_ROTATION_EXPIRY_ACTION=change
